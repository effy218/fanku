.pile-card {
  flex: 0 0 auto;
  width: 276rpx;
  margin-right: -92rpx;
  background: var(--paper, #fffaf0);
  border: 4rpx solid var(--ink, #3d2b1f);
  box-shadow: 6rpx 6rpx 0 var(--ink, #3d2b1f);
  overflow: hidden;
  position: relative;
  transition: transform 0.2s, margin 0.2s, box-shadow 0.2s;
  z-index: 1;
}

.pile-card.odd {
  transform: rotate(-1.5deg);
}

.pile-card.even {
  transform: rotate(1deg);
}

.pile-card:last-child {
  margin-right: 28rpx;
}

.pile-card-hover {
  transform: rotate(0deg) translateY(-8rpx) !important;
  margin-right: 16rpx;
  z-index: 5;
  box-shadow: 6rpx 6rpx 0 var(--brand, #c8703e);
}

.pc-photo {
  height: 192rpx;
  position: relative;
}

.pc-img {
  width: 100%;
  height: 100%;
  display: block;
}

.pc-lv {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  z-index: 2;
}

.pc-body {
  padding: 14rpx 18rpx 16rpx;
  background: var(--paper, #fffaf0);
}

.pc-name {
  font-weight: 800;
  font-size: 26rpx;
  color: var(--ink, #3d2b1f);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 1rpx;
}

.pc-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.pc-date {
  font-family: ui-monospace, 'Courier New', monospace;
  font-size: 16rpx;
  color: var(--ink-muted, #9c8970);
}
