.stars {
  display: inline-flex;
  align-items: center;
  gap: 2rpx;
}

.star-wrap {
  position: relative;
  width: var(--star-size, 36rpx);
  height: var(--star-size, 36rpx);
}

.star-hit {
  position: absolute;
  top: 0;
  width: 50%;
  height: 100%;
  z-index: 3;
}

.star-hit.left {
  left: 0;
}

.star-hit.right {
  right: 0;
}

.star {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.star-char {
  font-size: var(--star-size, 36rpx);
  line-height: 1;
  color: var(--cream-300, #edd9b8);
}

.star.full .star-char {
  color: var(--lv-strong, #e8a317);
}

.star.half .star-char {
  color: var(--cream-300, #edd9b8);
}

.star-half-mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 50%;
  height: 100%;
  overflow: hidden;
  z-index: 1;
}

.star-half-mask .star-char.on {
  color: var(--lv-strong, #e8a317);
  display: block;
  width: calc(var(--star-size, 36rpx) * 2);
}

.rate-val {
  margin-left: 12rpx;
  font-family: ui-monospace, 'Courier New', monospace;
  font-size: 20rpx;
  color: var(--ink, #3d2b1f);
  font-weight: 700;
}

.rate-val.brand {
  color: var(--brand, #c8703e);
}
