.tag-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  font-weight: 700;
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border: 4rpx solid var(--ink, #3d2b1f);
  background: var(--paper, #fffaf0);
  color: var(--ink-soft, #6b5440);
  box-shadow: 4rpx 4rpx 0 var(--ink, #3d2b1f);
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.chip-on {
  background: var(--brand, #c8703e);
  color: #fff;
}

.rm {
  opacity: 0.85;
}

.tag-add {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.tag-field {
  flex: 1;
  padding: 14rpx 18rpx;
  font-size: 26rpx;
}

.pinput {
  box-sizing: border-box;
  border: 4rpx solid var(--ink, #3d2b1f);
  background: var(--cream-50, #fffbf2);
  color: var(--ink, #3d2b1f);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  border: 4rpx solid var(--ink, #3d2b1f);
  background: var(--cream-200, #f5e8d0);
  box-shadow: 4rpx 4rpx 0 var(--ink, #3d2b1f);
  padding: 12rpx 24rpx;
}

.suggest-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}
