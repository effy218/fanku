.ico {
  position: relative;
  flex-shrink: 0;
  image-rendering: pixelated;
}

.grid {
  width: 100%;
  height: 100%;
  position: relative;
}

/* logo */
.logo .bg {
  position: absolute;
  inset: 0;
  background: #3d2b1f;
}

.logo .face {
  position: absolute;
  left: 12.5%;
  top: 12.5%;
  width: 75%;
  height: 75%;
  background: #fffbf2;
}

.logo .eye {
  position: absolute;
  top: 25%;
  width: 12.5%;
  height: 12.5%;
  background: #c8703e;
}

.logo .eye.l {
  left: 25%;
}

.logo .eye.r {
  right: 25%;
}

.logo .mouth {
  position: absolute;
  left: 25%;
  top: 40%;
  width: 50%;
  height: 12.5%;
  background: #d4a574;
}

.logo .lip {
  position: absolute;
  left: 37.5%;
  top: 68%;
  width: 25%;
  height: 6.5%;
  background: #c25b4e;
}

/* search — 放大镜近似 */
.search .ring {
  position: absolute;
  left: 12%;
  top: 8%;
  width: 56%;
  height: 56%;
  border: 6rpx solid #3d2b1f;
  border-radius: 50%;
  box-sizing: border-box;
}

.search .handle {
  position: absolute;
  right: 12%;
  bottom: 10%;
  width: 28%;
  height: 8rpx;
  background: #3d2b1f;
  transform: rotate(45deg);
  transform-origin: left center;
}

/* close X */
.close .x {
  position: absolute;
  left: 18%;
  top: 46%;
  width: 64%;
  height: 8rpx;
  background: #3d2b1f;
}

.close .x.a {
  transform: rotate(45deg);
}

.close .x.b {
  transform: rotate(-45deg);
}

/* onigiri */
.onigiri .body {
  position: absolute;
  left: 18%;
  top: 10%;
  width: 64%;
  height: 72%;
  background: #fffbf2;
  border: 4rpx solid #3d2b1f;
  border-radius: 50% 50% 42% 42%;
  box-sizing: border-box;
}

.onigiri .nori {
  position: absolute;
  left: 28%;
  bottom: 14%;
  width: 44%;
  height: 28%;
  background: #2d2d2d;
  border: 3rpx solid #3d2b1f;
  box-sizing: border-box;
}
