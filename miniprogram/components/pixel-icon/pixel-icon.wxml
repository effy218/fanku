<view class="ico" style="width:{{size}}rpx;height:{{size}}rpx;">
  <!-- logo 笑脸饭 -->
  <view wx:if="{{name === 'logo'}}" class="grid logo">
    <view class="c bg"></view>
    <view class="c face"></view>
    <view class="c eye l"></view>
    <view class="c eye r"></view>
    <view class="c mouth"></view>
    <view class="c lip"></view>
  </view>
  <!-- 搜索 -->
  <view wx:elif="{{name === 'search'}}" class="grid search">
    <view class="s ring"></view>
    <view class="s handle"></view>
  </view>
  <!-- 关闭 -->
  <view wx:elif="{{name === 'close'}}" class="grid close">
    <view class="x a"></view>
    <view class="x b"></view>
  </view>
  <!-- 饭团 -->
  <view wx:elif="{{name === 'onigiri'}}" class="grid onigiri">
    <view class="o body"></view>
    <view class="o nori"></view>
  </view>
</view>
