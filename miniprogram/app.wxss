/** 饭库 · 奶油像素风 — 对齐设计系统 V3 **/
page {
  --cream-50: #fffbf2;
  --cream-100: #fbf1e2;
  --cream-200: #f5e8d0;
  --cream-300: #edd9b8;
  --cream-400: #e0c99a;
  --ink: #3d2b1f;
  --ink-soft: #6b5440;
  --ink-muted: #9c8970;
  --paper: #fffaf0;
  --brand: #c8703e;
  --brand-deep: #a85528;
  --brand-soft: #e8b98f;
  --lv-strong: #e8a317;
  --lv-rec: #7a9b5a;
  --lv-normal: #9b8b7a;
  --lv-avoid: #c25b4e;
  --lv-strong-bg: #fbf1d8;
  --lv-rec-bg: #e8eedc;
  --lv-normal-bg: #efe9df;
  --lv-avoid-bg: #f3ddd9;
  --shadow-pixel: 8rpx 8rpx 0 var(--ink);

  background: var(--cream-100);
  color: var(--ink);
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.pix {
  font-weight: 800;
  letter-spacing: 2rpx;
}

.pix-sm {
  font-weight: 800;
  font-size: 26rpx;
  letter-spacing: 1rpx;
}

.mono {
  font-family: ui-monospace, 'Courier New', Consolas, monospace;
  letter-spacing: 1rpx;
}

/* 安全顶栏占位由各页 inline style 注入 */
.safe-pad {
  box-sizing: border-box;
}

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-weight: 800;
  font-size: 28rpx;
  border: 4rpx solid var(--ink);
  padding: 18rpx 36rpx;
  background: var(--cream-200);
  color: var(--ink);
  box-shadow: 6rpx 6rpx 0 var(--ink);
  line-height: 1.2;
}

.btn:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 2rpx 2rpx 0 var(--ink);
}

.btn-primary {
  background: var(--brand);
  color: #fff;
}

.btn-ghost {
  background: transparent;
  box-shadow: none;
  border-color: var(--ink-muted);
}

.btn-sm {
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  box-shadow: 4rpx 4rpx 0 var(--ink);
}

/* 等级角标 */
.lv-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-weight: 800;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border: 4rpx solid var(--ink);
  box-shadow: 4rpx 4rpx 0 var(--ink);
  line-height: 1.2;
}

.lv-badge.sm {
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-width: 3rpx;
  box-shadow: 2rpx 2rpx 0 var(--ink);
}

.lv-strong {
  background: var(--lv-strong);
  color: var(--ink);
}

.lv-rec {
  background: var(--lv-rec);
  color: #fff;
}

.lv-normal {
  background: var(--lv-normal);
  color: #fff;
}

.lv-avoid {
  background: var(--lv-avoid);
  color: #fff;
}

/* 输入 */
.pinput {
  width: 100%;
  box-sizing: border-box;
  font-size: 28rpx;
  border: 4rpx solid var(--ink);
  background: var(--cream-50);
  padding: 22rpx 26rpx;
  color: var(--ink);
  box-shadow: inset 4rpx 4rpx 0 rgba(61, 43, 31, 0.06);
}

.pinput-placeholder {
  color: var(--ink-muted);
}

.input-label {
  display: block;
  font-weight: 800;
  font-size: 26rpx;
  color: var(--ink);
  margin-bottom: 14rpx;
  text-align: left;
}

.input-label .req {
  color: var(--lv-avoid);
}

/* 复吃 */
.reeat {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-weight: 800;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border: 3rpx solid var(--ink);
}

.reeat-yes {
  background: var(--lv-rec-bg);
  color: var(--lv-rec);
}

.reeat-maybe {
  background: var(--lv-normal-bg);
  color: var(--ink-soft);
}

.reeat-no {
  background: var(--lv-avoid-bg);
  color: var(--lv-avoid);
}

.chip {
  display: inline-flex;
  align-items: center;
  font-weight: 800;
  font-size: 24rpx;
  padding: 10rpx 22rpx;
  border: 4rpx solid var(--ink);
  background: var(--paper);
  color: var(--ink-soft);
  box-shadow: 4rpx 4rpx 0 var(--ink);
  margin-right: 14rpx;
  margin-bottom: 14rpx;
}

.chip-on {
  background: var(--brand);
  color: #fff;
}

.more-toggle {
  font-weight: 800;
  font-size: 24rpx;
  color: var(--brand);
  text-align: center;
  padding: 22rpx;
  border: 4rpx dashed var(--brand);
  background: var(--brand-soft);
  margin-top: 32rpx;
  opacity: 0.95;
}

.more-toggle:active {
  opacity: 0.75;
}

.frame {
  border: 4rpx solid var(--ink);
  box-shadow: var(--shadow-pixel);
  background: var(--paper);
}

.empty-hint {
  text-align: center;
  color: var(--ink-muted);
  font-size: 26rpx;
  padding: 64rpx 32rpx;
}

/* 详情/编辑通用 */
.info-row {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  padding: 10rpx 0;
  font-size: 26rpx;
}

.info-label {
  font-weight: 800;
  font-size: 24rpx;
  color: var(--ink-muted);
  width: 84rpx;
  flex-shrink: 0;
  text-align: left;
}

.info-val {
  flex: 1;
  color: var(--ink);
  text-align: left;
}

.ds-title {
  font-weight: 800;
  font-size: 26rpx;
  color: var(--ink-soft);
  margin-bottom: 14rpx;
  text-align: left;
}

.note-box {
  background: var(--cream-100);
  border: 4rpx solid var(--ink);
  padding: 22rpx 26rpx;
  font-size: 26rpx;
  color: var(--ink);
  line-height: 1.9;
  text-align: left;
}

.dish-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: var(--ink);
  border-bottom: 2rpx dotted var(--cream-300);
}

.dish-line:last-child {
  border-bottom: none;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid var(--ink);
  display: inline-block;
  margin-right: 12rpx;
  vertical-align: middle;
}

.dot-must {
  background: var(--lv-strong);
}

.dot-ok {
  background: var(--lv-normal);
}

.dot-no {
  background: var(--lv-avoid);
}
