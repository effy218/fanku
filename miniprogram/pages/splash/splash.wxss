.splash {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--cream-100);
  gap: 28rpx;
}

.splash-bounce {
  animation: bob 1.6s ease-in-out infinite;
}

@keyframes bob {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-12rpx);
  }
}

.splash-logo {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.logo-text {
  font-weight: 800;
  font-size: 56rpx;
  color: var(--ink);
  letter-spacing: 8rpx;
}

.splash-sub {
  font-family: ui-monospace, 'Courier New', monospace;
  font-size: 16rpx;
  color: var(--ink-muted);
  letter-spacing: 4rpx;
}

.splash-bar {
  width: 240rpx;
  height: 16rpx;
  background: var(--cream-200);
  border: 4rpx solid var(--ink);
  overflow: hidden;
  margin-top: 8rpx;
  position: relative;
}

.splash-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 40%;
  background: var(--brand);
  animation: load 1.4s ease-in-out infinite;
}

@keyframes load {
  0% {
    left: -40%;
  }
  100% {
    left: 100%;
  }
}
