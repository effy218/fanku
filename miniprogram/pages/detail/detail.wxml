<view class="page" wx:if="{{card}}">
  <scroll-view scroll-y class="phone-scroll" enhanced show-scrollbar="{{false}}">
    <!-- 设计稿顶栏：‹ 返回 + 等级角标 -->
    <view class="detail-topbar" style="padding-top: {{statusPad + 10}}px;">
      <view class="detail-back" bindtap="onBack" hover-class="btn-press">‹</view>
      <view class="detail-right">
        <level-badge level="{{card.level}}" />
        <text class="detail-edit" bindtap="onEdit">编辑</text>
      </view>
    </view>

    <view class="detail-body">
      <view class="detail-name">{{card.name}}</view>

      <view class="detail-info">
        <view class="info-row" wx:if="{{card.location}}">
          <text class="info-label">位置</text>
          <text class="info-val">{{card.location}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">日期</text>
          <text class="info-val mono date-val">{{dateText}}</text>
        </view>
        <view class="info-row" wx:if="{{cuisineText}}">
          <text class="info-label">菜系</text>
          <text class="info-val">{{cuisineText}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">口味</text>
          <view class="info-val stars-row">
            <star-rating value="{{card.taste}}" readonly show-value size="{{30}}" />
          </view>
        </view>
        <view class="info-row">
          <text class="info-label">复吃</text>
          <view class="info-val">
            <text class="reeat {{reeatClass}}">{{reeatLabel}}</text>
          </view>
        </view>
      </view>

      <!-- 照片：始终展示区块（无图用占位） -->
      <view class="detail-section">
        <view class="ds-title">照片</view>
        <block wx:if="{{card.photos.length}}">
          <scroll-view scroll-x class="photo-scroll" enhanced show-scrollbar="{{false}}">
            <view class="photo-row">
              <image
                wx:for="{{card.photos}}"
                wx:key="*this"
                class="detail-photo"
                src="{{item}}"
                mode="aspectFill"
              />
            </view>
          </scroll-view>
        </block>
        <view wx:else class="detail-photo ph">
          <text class="photo-ph">照片位置 · 用户拍</text>
        </view>
      </view>

      <view class="detail-section" wx:if="{{card.note}}">
        <view class="ds-title">手账</view>
        <view class="note-box">{{card.note}}</view>
      </view>

      <view class="detail-section" wx:if="{{card.dishes && card.dishes.length}}">
        <view class="ds-title">菜品</view>
        <view wx:for="{{card.dishes}}" wx:key="index" class="dish-line">
          <text>
            <text class="dot dot-{{item.mark}}"></text>{{item.name}}
          </text>
          <text class="dish-mark mark-{{item.mark}}">{{dishMarks[item.mark]}}</text>
        </view>
      </view>

      <!-- 自定义维度收进「展开更多」 -->
      <view
        wx:if="{{dimRows.length}}"
        class="more-toggle"
        bindtap="toggleMore"
      >{{showMore ? '收起更多' : '＋ 展开更多（自定义维度）'}}</view>

      <view wx:if="{{showMore}}" class="more-block">
        <view class="detail-section" wx:for="{{dimRows}}" wx:key="def.id">
          <dim-field
            def="{{item.def}}"
            value="{{item.value}}"
            display-text="{{item.displayText}}"
            readonly
          />
        </view>
      </view>

      <view class="danger-row" bindtap="onDelete">删除饭卡</view>
    </view>
  </scroll-view>
</view>
