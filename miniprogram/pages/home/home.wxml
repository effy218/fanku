<view class="page">
  <scroll-view scroll-y class="phone-scroll" enhanced show-scrollbar="{{false}}">
    <!-- 顶栏：logo + 折叠搜索（对齐设计稿，无双导航） -->
    <view class="home-header {{searchExpanded ? 'expanded' : ''}}" style="padding-top: {{statusPad + 14}}px;">
      <view class="home-title">
        <view class="ht-logo" bindlongpress="onLogoLongPress">
          <pixel-icon name="logo" size="{{44}}" />
          <text class="ht-text">饭库</text>
        </view>
        <view class="home-search-btn" bindtap="toggleSearch" hover-class="btn-press">
          <pixel-icon wx:if="{{!searchExpanded}}" name="search" size="{{32}}" />
          <pixel-icon wx:else name="close" size="{{28}}" />
        </view>
      </view>
      <view class="home-search-expand">
        <view class="search-box">
          <pixel-icon name="search" size="{{28}}" />
          <input
            class="search-input"
            placeholder="搜索店名、菜品、笔记"
            placeholder-class="pinput-placeholder"
            value="{{keyword}}"
            confirm-type="search"
            bindinput="onSearchInput"
            bindconfirm="onSearchConfirm"
            focus="{{searchExpanded}}"
          />
        </view>
      </view>
    </view>

    <view wx:if="{{empty}}" class="empty-hint">
      <view class="pix" style="font-size:36rpx;margin-bottom:16rpx;color:var(--ink)">还没有饭卡</view>
      <view>点右下角「＋」记下第一顿</view>
      <view style="margin-top:12rpx;font-size:22rpx">长按左上角 Logo 可管理维度模板</view>
    </view>

    <view class="home-piles">
      <block wx:for="{{piles}}" wx:key="key">
        <view class="pile-wrap">
          <view class="pile-head">
            <view class="pile-dot" style="background:{{item.color}}"></view>
            <text class="pile-title">{{item.title}}</text>
            <text class="pile-count">{{item.count}}</text>
            <text class="pile-hint">‹ 滑动 ›</text>
          </view>
          <scroll-view wx:if="{{item.count > 0}}" scroll-x class="pile" enhanced show-scrollbar="{{false}}" enable-flex>
            <view class="pile-inner">
              <block wx:for="{{item.cards}}" wx:for-item="card" wx:key="id">
                <pile-card
                  card-id="{{card.id}}"
                  name="{{card.name}}"
                  date="{{card.date}}"
                  level="{{card.level}}"
                  taste="{{card.taste}}"
                  photo="{{card.photo}}"
                  odd="{{card.odd}}"
                  photo-bg="{{card.photoBg}}"
                  bind:cardtap="onCardTap"
                />
              </block>
            </view>
          </scroll-view>
          <view wx:else class="pile-empty">暂无 · 记一顿放进这堆</view>
        </view>
      </block>
    </view>
    <view class="bottom-spacer"></view>
  </scroll-view>

  <view class="home-fab" bindtap="onFab" hover-class="btn-press">＋</view>
</view>
