<view class="page">
  <scroll-view scroll-y class="phone-scroll" enhanced show-scrollbar="{{false}}">
    <!-- 设计稿编辑顶栏：✕ + 标题 | 保存 -->
    <view class="edit-header" style="padding-top: {{statusPad + 12}}px;">
      <view class="eh-left">
        <text class="eh-close" bindtap="onClose">✕</text>
        <text class="eh-title">{{isNew ? '新建饭卡' : '编辑饭卡'}}</text>
      </view>
      <view class="btn btn-sm btn-primary save-btn" bindtap="onSave" hover-class="btn-press">保存</view>
    </view>

    <view class="edit-body">
      <view class="edit-section">
        <label class="input-label">店名 <text class="req">*</text></label>
        <input class="pinput" value="{{card.name}}" placeholder="店名" placeholder-class="pinput-placeholder" bindinput="onName" />
      </view>

      <view class="edit-section">
        <label class="input-label">位置</label>
        <input class="pinput" value="{{card.location}}" placeholder="朝阳区·三里屯" placeholder-class="pinput-placeholder" bindinput="onLocation" />
      </view>

      <view class="edit-section">
        <label class="input-label">日期 <text class="req">*</text></label>
        <picker mode="date" value="{{card.date}}" bindchange="onDateChange">
          <view class="pinput mono date-input">{{card.date}}</view>
        </picker>
      </view>

      <view class="edit-section">
        <label class="input-label">菜系</label>
        <tag-input
          tags="{{card.cuisines}}"
          suggestions="{{cuisineSuggestions}}"
          placeholder="添加菜系标签…"
          bind:change="onCuisines"
        />
      </view>

      <view class="edit-section">
        <label class="input-label">口味评分 <text class="req">*</text></label>
        <star-rating value="{{card.taste}}" show-value brand-value bind:change="onTaste" />
      </view>

      <view class="edit-section">
        <label class="input-label">等级 <text class="req">*</text></label>
        <view class="level-row">
          <view
            wx:for="{{levels}}"
            wx:key="key"
            class="level-opt {{card.level === item.key ? 'on' : ''}}"
            data-level="{{item.key}}"
            bindtap="onLevel"
          >
            <level-badge level="{{item.key}}" size="sm" short />
          </view>
        </view>
      </view>

      <view class="edit-section">
        <label class="input-label">复吃意愿 <text class="req">*</text></label>
        <ternary-toggle value="{{reeatIndex}}" options="{{reeatOpts}}" bind:change="onReeat" />
      </view>

      <view class="edit-section">
        <label class="input-label">照片 <text class="mono muted">0-9</text></label>
        <view class="photo-grid">
          <view
            wx:for="{{card.photos}}"
            wx:key="*this"
            class="photo-cell filled"
            data-index="{{index}}"
            bindtap="onRemovePhoto"
          >
            <image src="{{item}}" mode="aspectFill" class="photo-img" />
            <text class="photo-rm">×</text>
          </view>
          <view
            wx:if="{{card.photos.length < 9}}"
            class="photo-cell"
            bindtap="onChoosePhoto"
          >＋</view>
          <!-- 占位格对齐设计稿空格感 -->
          <block wx:if="{{card.photos.length < 5}}">
            <view
              wx:for="{{photoSlots}}"
              wx:key="*this"
              wx:if="{{index < (5 - card.photos.length)}}"
              class="photo-cell ghost"
              bindtap="onChoosePhoto"
            >＋</view>
          </block>
        </view>
      </view>

      <view class="edit-section">
        <label class="input-label">手账</label>
        <textarea
          class="pinput note-area"
          value="{{card.note}}"
          placeholder="记下这顿饭的感受…"
          placeholder-class="pinput-placeholder"
          maxlength="1000"
          bindinput="onNote"
        />
      </view>

      <view class="edit-section">
        <label class="input-label">菜品</label>
        <view wx:for="{{card.dishes}}" wx:key="index" class="dish-line">
          <text>
            <text class="dot dot-{{item.mark}}"></text>{{item.name}}
          </text>
          <text class="dish-side">
            <text class="mark-{{item.mark}}">{{item.mark === 'must' ? '必点' : item.mark === 'no' ? '踩雷' : ''}}</text>
            <text class="dish-rm" data-index="{{index}}" catchtap="removeDish"> ✕</text>
          </text>
        </view>
        <view class="dish-add-row">
          <input
            class="pinput dish-input"
            value="{{dishDraft}}"
            placeholder="加一道菜…"
            placeholder-class="pinput-placeholder"
            bindinput="onDishDraft"
            bindconfirm="addDish"
          />
          <view class="btn btn-sm" bindtap="addDish" hover-class="btn-press">＋</view>
        </view>
        <view class="mark-picks">
          <text
            wx:for="{{dishMarkOpts}}"
            wx:key="key"
            class="mark-pick {{dishMarkIndex === index ? 'on' : ''}}"
            data-index="{{index}}"
            bindtap="onDishMark"
          >{{item.label}}</text>
        </view>
      </view>

      <view class="edit-section" wx:for="{{activeDims}}" wx:key="def.id">
        <dim-field
          def="{{item.def}}"
          value="{{item.value}}"
          data-id="{{item.def.id}}"
          bind:change="onDimChange"
        />
      </view>

      <view class="more-toggle" bindtap="toggleMorePanel">
        ＋ 添加更多（自定义维度）
      </view>

      <view wx:if="{{showMorePanel}}" class="more-panel frame">
        <view class="more-title">可选维度</view>
        <view
          wx:for="{{hiddenDefs}}"
          wx:key="id"
          class="more-item"
          data-id="{{item.id}}"
          bindtap="addDim"
        >
          <text>{{item.name}}</text>
          <text class="more-type">{{item.type === 'text' ? '文本' : item.type === 'stars' ? '星级' : item.type === 'binary' ? '二态' : '三态'}}</text>
        </view>
        <view wx:if="{{!hiddenDefs.length}}" class="more-empty">已全部添加，或去模板新建</view>
        <view class="more-item link" bindtap="goTemplate">管理维度模板 →</view>
      </view>

      <view class="bottom-spacer"></view>
    </view>
  </scroll-view>
</view>
