.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--cream-100);
}

.search-header {
  padding: 14px 28rpx 20rpx;
  background: var(--cream-100);
  border-bottom: 4rpx solid var(--ink);
  flex-shrink: 0;
}

.search-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.back {
  font-weight: 800;
  font-size: 40rpx;
  color: var(--ink);
  line-height: 1;
  padding: 0 4rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--paper);
  border: 4rpx solid var(--ink);
  padding: 14rpx 18rpx;
  box-shadow: 4rpx 4rpx 0 var(--ink);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--ink);
  height: 40rpx;
}

.clear {
  color: var(--ink-muted);
  padding: 4rpx 8rpx;
  font-weight: 700;
}

.search-body {
  flex: 1;
  height: 0;
}

.search-suggest,
.search-result {
  padding: 28rpx;
}

.suggest-title {
  font-weight: 800;
  font-size: 24rpx;
  color: var(--ink-muted);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.suggest-tags {
  display: flex;
  flex-wrap: wrap;
}

.chip-press {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 var(--ink);
}

.result-count {
  font-family: ui-monospace, 'Courier New', monospace;
  font-size: 18rpx;
  color: var(--ink-muted);
  margin-bottom: 20rpx;
}

.result-card {
  margin-bottom: 20rpx;
  border: 4rpx solid var(--ink);
  box-shadow: 4rpx 4rpx 0 var(--ink);
  background: var(--paper);
  overflow: hidden;
}

.card-press {
  box-shadow: 2rpx 2rpx 0 var(--ink);
  transform: translate(2rpx, 2rpx);
}

.result-photo {
  height: 120rpx;
  background: var(--cream-300);
  position: relative;
}

.result-photo.ph {
  background: var(--cream-300);
}

.rp-img {
  width: 100%;
  height: 100%;
}

.rp-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
}

.result-body {
  padding: 18rpx 24rpx;
}

.result-name {
  font-weight: 800;
  font-size: 28rpx;
  color: var(--ink);
  display: block;
}

.result-hint {
  font-size: 22rpx;
  color: var(--ink-soft);
  margin-top: 8rpx;
  display: block;
}

.result-date {
  margin-top: 8rpx;
  color: var(--ink-muted);
  font-size: 16rpx;
}
