.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--cream-100);
}

.tpl-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 28rpx 16rpx;
  background: var(--cream-100);
  border-bottom: 4rpx solid var(--ink);
  flex-shrink: 0;
}

.detail-back {
  width: 60rpx;
  height: 60rpx;
  background: var(--paper);
  border: 4rpx solid var(--ink);
  box-shadow: 4rpx 4rpx 0 var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--ink);
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
}

.btn-press {
  transform: translate(4rpx, 4rpx);
  box-shadow: 2rpx 2rpx 0 var(--ink) !important;
}

.tpl-title {
  font-weight: 800;
  font-size: 30rpx;
  color: var(--ink);
  letter-spacing: 2rpx;
}

.tpl-spacer {
  width: 60rpx;
}

.tpl-scroll {
  flex: 1;
  height: 0;
}

.tpl-body {
  padding: 28rpx;
}

.intro {
  font-size: 26rpx;
  color: var(--ink-soft);
  margin-bottom: 28rpx;
  line-height: 1.7;
}

.def-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.def-main {
  margin-bottom: 16rpx;
}

.def-name {
  font-size: 30rpx;
  color: var(--ink);
  margin-bottom: 8rpx;
}

.def-meta {
  display: flex;
  gap: 12rpx;
}

.type-tag {
  font-family: 'Courier New', monospace;
  font-size: 18rpx;
  background: var(--cream-200);
  padding: 6rpx 12rpx;
  color: var(--ink-muted);
}

.en-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border: 3rpx solid var(--ink-muted);
  color: var(--ink-muted);
}

.en-tag.on {
  border-color: var(--lv-rec);
  color: var(--lv-rec);
  background: var(--lv-rec-bg);
}

.def-actions {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.act {
  font-weight: 700;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border: 3rpx solid var(--ink);
  background: var(--cream-200);
  box-shadow: 3rpx 3rpx 0 var(--ink);
}

.act.danger {
  color: var(--lv-avoid);
}

.add-btn {
  width: 100%;
  box-sizing: border-box;
  margin-top: 16rpx;
}

.bottom-spacer {
  height: 80rpx;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(61, 43, 31, 0.45);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: var(--cream-50);
  border-top: 4rpx solid var(--ink);
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
  box-sizing: border-box;
}

.sheet-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.sheet-close {
  font-size: 36rpx;
  color: var(--ink);
  padding: 8rpx;
}

.edit-section {
  margin-bottom: 24rpx;
}

.opt-row {
  display: flex;
  gap: 12rpx;
}

.opt-row .half {
  flex: 1;
}

.opt-row.three .third {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
}

.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.sheet-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.sheet-btns .btn {
  flex: 1;
}
